# Copy your OpenAI key here
OPENAI_API_KEY=''
DEEPSEEK_KEY=''
# Optional controls (defaults are shown)
DIALOG_N=300
DIALOG_WORKERS=20
SEED=4224
MODEL='gpt-5.2'

# Rebuild the financial dataset JSON even if it already exists.
# REBUILD_DATASET=1

# Dialog generation mode:
# - phases: persona+outline+phases+state (slower)
# - field_chunks: generate by field batches with inline evidence (faster; recommended for debugging coverage)
DIALOG_MODE=field_chunks
#DIALOG_REGISTRY_SKIP_STATUSES=success

# Networking safeguards (optional)
# OPENAI_TIMEOUT_S=90
# OPENAI_MAX_RETRIES=2

MIN_TURNS=500
MAX_TURNS=900
MAX_OUTPUT_TOKENS=3000
PERSONAS_MAX_OUTPUT_TOKENS=900
OUTLINE_MAX_OUTPUT_TOKENS=1100
PHASE_MAX_OUTPUT_TOKENS=1400
STATE_MAX_OUTPUT_TOKENS=800
CONTEXT_LAST_UTTERANCES=30
CONTEXT_SUMMARY_LAST_PHASES=4
CONTEXT_SUMMARY_MAX_CHARS=1200

# Evidence / verification artifacts
SAVE_EVIDENCE_JSON=1
EVIDENCE_BATCH_SIZE=4
EVIDENCE_MAX_OUTPUT_TOKENS=2800

SAVE_METRICS_JSON=1
REQUIRE_VALIDATION_PASS=1
VALIDATION_STRICT=0

# Evidence strategy:
# - 0: inline evidence (only for field_chunks)
# - 1: post-hoc evidence extraction pass (phases mode)
EVIDENCE_POSTHOC=0

# Field-chunks chunk shaping
FIELD_CHUNK_GROUP_BY_RECORD_TYPE=1
FIELD_CHUNK_SHUFFLE_WITHIN_GROUP=1

# Optional finalize step after validation passes
FINALIZE_TRANSCRIPT=1
FINALIZE_STRATEGY=realism_merge
FINALIZE_MAX_OUTPUT_TOKENS=3200
DEEPSEEK_REALISM_CHECK=1
DEEPSEEK_MODEL='deepseek-chat'
DEEPSEEK_MAX_OUTPUT_TOKENS=900
DEEPSEEK_REALISM_THRESHOLD=4
DEEPSEEK_PASS_SUBDIR='realism_passed'

# Example transcripts injected into the phase-generation prompt:
# - excerpt: include short excerpts from both example transcripts (recommended)
# - full: include full text of both examples (very large)
# - none: do not include examples
# EXAMPLE_TRANSCRIPTS_MODE=excerpt

# Recap / misunderstanding throttles (defaults shown; roughly "1 per 10 utterances")
RECAP_WINDOW_UTTERANCES=10
RECAP_MAX_PER_WINDOW=1
MISUNDERSTANDING_WINDOW_UTTERANCES=10
MISUNDERSTANDING_MAX_PER_WINDOW=1
